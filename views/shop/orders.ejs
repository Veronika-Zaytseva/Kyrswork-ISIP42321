<%- include('../partials/head') %><%- include('../partials/header') %>
<main class="container"><h1>Мои заказы</h1>
<% if (!orders.length) { %><p>У вас пока нет заказов.</p><% } %>
<% orders.forEach(order => { %><div class="order-card">
<h3>Заказ №<%= order.id %></h3>
<p>Статус: <strong><%= order.status %></strong></p>
<p>Сумма: <strong><%= Number(order.total_amount).toFixed(2) %> ₽</strong></p>
<p>Адрес: <%= order.delivery_address %></p>
<p>Дата: <%= new Date(order.created_at).toLocaleString('ru-RU') %></p>
<div class="order-items"><% order.items.forEach(item => { %><div class="order-item-row"><span><%= item.product_name %> / <%= item.size_name %></span><span><%= item.quantity %> × <%= Number(item.price).toFixed(2) %> ₽</span></div><% }) %></div>
</div><% }) %>
</main><%- include('../partials/footer') %>
