<%- include('../partials/head') %><%- include('../partials/header') %>
<main class="container">
<h1>Каталог товаров</h1>
<form method="GET" action="/catalog" class="filter-form">
<input type="text" name="search" placeholder="Поиск..." value="<%= filters.search %>" />
<select name="category"><option value="">Все категории</option><% categories.forEach(item => { %><option value="<%= item.category %>" <%= filters.category === item.category ? 'selected' : '' %>><%= item.category %></option><% }) %></select>
<select name="gender">
<option value="">Для всех</option>
<option value="male" <%= filters.gender === 'male' ? 'selected' : '' %>>Мужское</option>
<option value="female" <%= filters.gender === 'female' ? 'selected' : '' %>>Женское</option>
<option value="unisex" <%= filters.gender === 'unisex' ? 'selected' : '' %>>Unisex</option>
</select>
<input type="number" step="0.01" name="minPrice" placeholder="Цена от" value="<%= filters.minPrice %>" />
<input type="number" step="0.01" name="maxPrice" placeholder="Цена до" value="<%= filters.maxPrice %>" />
<select name="sort">
<option value="newest" <%= filters.sort === 'newest' ? 'selected' : '' %>>Сначала новые</option>
<option value="price_asc" <%= filters.sort === 'price_asc' ? 'selected' : '' %>>Цена ↑</option>
<option value="price_desc" <%= filters.sort === 'price_desc' ? 'selected' : '' %>>Цена ↓</option>
<option value="name_asc" <%= filters.sort === 'name_asc' ? 'selected' : '' %>>По названию</option>
</select>
<button type="submit" class="btn">Применить</button>
</form>
<div class="product-grid">
<% if (!products.length) { %><p>Товары не найдены.</p><% } %>
<% products.forEach(product => { %>
<div class="product-card">
<img src="<%= product.image_url || '/uploads/no-image.png' %>" alt="<%= product.name %>" />
<h3><%= product.name %></h3><p><%= product.category %></p><strong><%= Number(product.price).toFixed(2) %> ₽</strong>
<a href="/products/<%= product.id %>" class="btn">Подробнее</a>
</div>
<% }) %>
</div>
<div class="pagination">
<% for (let p = 1; p <= pagination.totalPages; p++) { %>
<a class="page-link <%= p === pagination.currentPage ? 'active' : '' %>" href="/catalog?search=<%= encodeURIComponent(filters.search || '') %>&category=<%= encodeURIComponent(filters.category || '') %>&gender=<%= encodeURIComponent(filters.gender || '') %>&minPrice=<%= filters.minPrice || '' %>&maxPrice=<%= filters.maxPrice || '' %>&sort=<%= encodeURIComponent(filters.sort || 'newest') %>&page=<%= p %>"><%= p %></a>
<% } %>
</div>
</main><%- include('../partials/footer') %>
