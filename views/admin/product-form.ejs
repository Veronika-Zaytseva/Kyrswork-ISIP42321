<%- include('../partials/head') %><%- include('../partials/header') %>
<main class="container"><h1><%= product ? 'Редактирование товара' : 'Добавление товара' %></h1>
<form action="<%= product ? '/admin/products/' + product.id : '/admin/products' %>" method="POST" enctype="multipart/form-data" class="form-card">
<label>Название</label><input type="text" name="name" value="<%= product ? product.name : '' %>" required />
<label>Описание</label><textarea name="description" rows="5" required><%= product ? product.description : '' %></textarea>
<label>Категория</label><input type="text" name="category" value="<%= product ? product.category : '' %>" required />
<label>Тип</label>
<select name="gender" required>
<option value="male" <%= product && product.gender === 'male' ? 'selected' : '' %>>Мужское</option>
<option value="female" <%= product && product.gender === 'female' ? 'selected' : '' %>>Женское</option>
<option value="unisex" <%= !product || product.gender === 'unisex' ? 'selected' : '' %>>Unisex</option>
</select>
<label>Цена</label><input type="number" step="0.01" name="price" value="<%= product ? product.price : '' %>" required />
<label>Изображение товара</label><input type="file" name="image" accept=".jpg,.jpeg,.png,.webp" />
<% if (product && product.image_url) { %><p><img src="<%= product.image_url %>" class="preview-image" /></p><% } %>
<label>Размеры и остатки</label><input type="text" name="sizes" value="<%= sizesString %>" placeholder="S:10, M:5, L:3" />
<label class="checkbox-label"><input type="checkbox" name="is_active" <%= !product || product.is_active ? 'checked' : '' %> /> Активный товар</label>
<button type="submit" class="btn"><%= product ? 'Сохранить изменения' : 'Создать товар' %></button>
</form></main><%- include('../partials/footer') %>
