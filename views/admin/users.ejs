<%- include('../partials/head') %><%- include('../partials/header') %>
<main class="container"><h1>Пользователи</h1>
<table class="table"><thead><tr><th>ID</th><th>Имя</th><th>Email</th><th>Роль</th><th>Заказов</th><th>Дата регистрации</th></tr></thead><tbody>
<% users.forEach(user => { %><tr><td><%= user.id %></td><td><%= user.name %></td><td><%= user.email %></td><td><%= user.role %></td><td><%= user.orders_count %></td><td><%= new Date(user.created_at).toLocaleString('ru-RU') %></td></tr><% }) %>
</tbody></table></main><%- include('../partials/footer') %>
