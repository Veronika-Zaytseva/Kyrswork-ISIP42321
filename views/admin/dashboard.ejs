<%- include('../partials/head') %><%- include('../partials/header') %>
<main class="container"><div class="admin-header"><h1>Админ-панель</h1><div class="admin-actions"><a href="/admin/products/new" class="btn">Добавить товар</a><a href="/admin/orders" class="btn btn-outline">Заказы</a><a href="/admin/users" class="btn btn-outline">Пользователи</a></div></div>
<table class="table"><thead><tr><th>ID</th><th>Изображение</th><th>Название</th><th>Категория</th><th>Цена</th><th>Активен</th><th>Действия</th></tr></thead><tbody>
<% products.forEach(product => { %><tr>
<td><%= product.id %></td><td><img src="<%= product.image_url || '/uploads/no-image.png' %>" class="thumb" /></td><td><%= product.name %></td><td><%= product.category %></td><td><%= Number(product.price).toFixed(2) %> ₽</td><td><%= product.is_active ? 'Да' : 'Нет' %></td>
<td><a href="/admin/products/<%= product.id %>/edit" class="btn btn-outline">Редактировать</a><form action="/admin/products/<%= product.id %>/delete" method="POST" class="inline-form"><button type="submit" class="btn btn-danger">Удалить</button></form></td>
</tr><% }) %>
</tbody></table></main><%- include('../partials/footer') %>
