<%- include('../partials/head') %><%- include('../partials/header') %>
<main class="container auth-page"><h1>Новый пароль</h1>
<form action="/auth/reset-password/<%= token %>" method="POST" class="form-card">
<label>Новый пароль</label><input type="password" name="password" required />
<label>Подтвердите пароль</label><input type="password" name="confirmPassword" required />
